# Loveca Client Environment Variables
# Copy this file to .env.local and fill in your configuration

# Optional API origin override.
# Leave empty for same-origin API. In local Vite dev, /api is proxied to http://localhost:3007 by vite.config.ts.
# Set only when the browser should call a different API/image proxy origin.
VITE_API_BASE_URL=

# Offline play is selected in the app UI; it is not controlled by VITE_API_BASE_URL.
# Email verification/password reset UI is loaded from /api/config and follows the server EMAIL_ENABLED + SMTP readiness.
