# Loveca Client Environment Variables
# Copy this file to .env.local and fill in your configuration

# API Base URL (required for online features)
# Points to the self-hosted API server (same origin in production via Nginx proxy)
# For development, leave empty to use Vite proxy (configured in vite.config.ts)
VITE_API_BASE_URL=

# If not configured, the app runs in offline mode
