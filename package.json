{
  "name": "loveca",
  "version": "3.8.0",
  "description": "Loveca 卡牌游戏后端",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:server": "tsc -p tsconfig.server.json",
    "dev": "tsc --watch",
    "dev:shared:build": "tsc --watch",
    "dev:server:build": "tsc -p tsconfig.server.json --watch",
    "dev:server": "node --env-file=.env --watch dist/server/index.js",
    "dev:online-service1": "pnpm --dir client dev:debug-service1",
    "dev:online-service2": "pnpm --dir client dev:debug-service2",
    "test": "vitest",
    "test:run": "vitest run",
    "test:real-data:online": "RUN_REAL_DATA_ONLINE=1 vitest run tests/integration/real-data-online-replay-harness.test.ts",
    "test:real-data:online:strict": "RUN_REAL_DATA_ONLINE=1 REAL_DATA_STRICT_STAGE_CARD_STATES=1 vitest run tests/integration/real-data-online-replay-harness.test.ts",
    "test:perf:online": "RUN_PERF=1 vitest run tests/performance/online-performance.bench.test.ts",
    "test:perf:solitaire": "RUN_PERF=1 vitest run tests/performance/solitaire-recording-performance.bench.test.ts",
    "test:perf:inspection": "RUN_PERF=1 vitest run tests/performance/inspection-hot-paths.bench.test.ts",
    "test:perf:hot-paths": "RUN_PERF=1 vitest run tests/performance/*.bench.test.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "version:check": "node scripts/check-version-consistency.mjs",
    "typecheck": "pnpm typecheck:shared && pnpm typecheck:server",
    "typecheck:shared": "tsc --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "pnpm --dir client exec tsc -b",
    "typecheck:all": "pnpm typecheck && pnpm typecheck:client",
    "android:pwa:build": "pnpm --dir client build",
    "android:assetlinks": "node scripts/generate-android-assetlinks.mjs",
    "android:twa:doctor": "node scripts/check-android-packaging-prereqs.mjs",
    "android:twa:build:docker": "node scripts/build-android-twa-docker.mjs",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "build:client": "cd client && pnpm build",
    "start:prod": "cd client && pnpm preview --port 4173 --host",
    "test-env:start": "bash scripts/start-test-env.sh",
    "clean": "rm -rf dist client/dist"
  },
  "keywords": [
    "loveca",
    "card-game",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=22.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@cloudbase/node-sdk": "^3.18.3",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "ws": "^8.21.0",
    "yaml": "^2.8.2",
    "zod": "^4.2.1"
  }
}
