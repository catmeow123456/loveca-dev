# DashScope AI proxy (optional; used by the client dev proxy for /api/dashscope)
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-your_api_key

# API Server
PORT=3007
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://loveca:loveca_dev@localhost:5432/loveca
POSTGRES_PASSWORD=loveca_dev

# Tencent CloudBase (optional; used by sync-cards-loveca-excel.ts --source=cloudbase)
CLOUDBASE_ENV_ID=your_cloudbase_env_id
CLOUDBASE_SECRET_ID=your_tencent_secret_id
CLOUDBASE_SECRET_KEY=your_tencent_secret_key

# JWT (use random strings of 32+ characters)
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_chars

# MinIO
# localhost:9000 is the local test default. If you use it, make sure MinIO is
# configured and card image/static resources have been preprocessed/uploaded.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=loveca-cards
MINIO_USE_SSL=false

# SMTP (optional, for email verification and password reset)
# Set EMAIL_ENABLED=true only when SMTP_* is configured. The client reads this capability from /api/config.
EMAIL_ENABLED=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password
# SMTP_FROM=noreply@loveca.app

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
